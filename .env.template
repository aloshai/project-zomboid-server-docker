# Empty Strings are ignored or equivalent to false

# Steam beta branch to install. "unstable" = Build 42 (default). "public" = Build 41 stable.
STEAM_BETA=unstable

LANG=en_EN.UTF-8
NOSTEAM=False
CACHEDIR=
MODFOLDERS=workshop,steam,mods
DEBUG=False
ADMINUSERNAME=admin
ADMINPASSWORD=ChangeMePlease
SERVERNAME=
SERVERPRESET=
IP=
PORT=16261
STEAMVAC=True
STEAMPORT1=
STEAMPORT2=
MEMORY=2048m
SOFTRESET=False
MOD_IDS=
WORKSHOP_IDS=

# ---- Web admin UI ----
# Domain Traefik routes the UI on (e.g. pz-admin.example.com). Used by the
# traefik.http router label in docker-compose.yml.
UI_DOMAIN=
# Login credentials for the admin UI. Login is DISABLED until a password is set.
UI_ADMIN_USER=admin
UI_ADMIN_PASSWORD=
# Secret used to sign UI session cookies. Set to a long random string.
UI_SESSION_SECRET=
# Port the UI listens on inside the container (matches the Traefik service port).
UI_PORT=8080
